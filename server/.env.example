# EastGold admin API — environment variables.
# Copy to `server/.env` and fill in real values (the .env file is gitignored).

# MongoDB Atlas connection string (required in production).
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/eastgold?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/eastgold

# Secret used to sign admin JWTs — set a long random value in production.
JWT_SECRET=eastgold-admin-secret-change-me

# How long an admin session token stays valid.
TOKEN_TTL=8h

# HTTP port the API listens on.
PORT=3000

# Comma-separated list of allowed CORS origins (the frontend URLs).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Bootstrap admin account (seeded into admin_users on first run).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
